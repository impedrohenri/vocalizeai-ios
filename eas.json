{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "env": {
         "EXPO_PUBLIC_APP_VERSION": "1.4.0"
      }
    },
    "production": {
      "extends": "base",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vocalizeai.app.br/api",
        "EXPO_PUBLIC_API_KEY": "b5694358-82bd-4bf0-81ab-32df891b5f86",
        "EXPO_PUBLIC_PROJECT_ID": "77d58605-b504-492e-a756-14a11c9b4265"
      },
      "autoIncrement": true
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vocalizeai.app.br/dev-api",
        "EXPO_PUBLIC_API_KEY": "21eb8838-1787-40df-916f-3011a86c1b48",
        "EXPO_PUBLIC_PROJECT_ID": "4207591d-1878-448c-b44f-a3d6f6f4fd48",
        "APP_VARIANT": "development"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vocalizeai.app.br/dev-api",
        "EXPO_PUBLIC_API_KEY": "21eb8838-1787-40df-916f-3011a86c1b48",
        "EXPO_PUBLIC_PROJECT_ID": "5fa1b7a6-f0f5-469a-821d-13252309d8ae",
        "APP_VARIANT": "preview"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    }
  }
}
